# =============================================================================
# Copy this file to .env and fill in your values for local development.
# Set all of these as Environment Variables in your Vercel project dashboard.
# =============================================================================

# -- Clerk Authentication ------------------------------------------------------
# https://dashboard.clerk.com -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# -- Supabase ------------------------------------------------------------------
# https://supabase.com/dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -- Database (Postgres) -------------------------------------------------------
# From Supabase -> Project Settings -> Database -> Connection string
# DATABASE_URL  -> Transaction/Session pooler (port 6543, pgbouncer=true)
# DIRECT_URL    -> Direct connection (port 5432) -- used only for migrations
DATABASE_URL=
DIRECT_URL=

# -- Google Gemini API ---------------------------------------------------------
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# -- Arcjet (Rate Limiting & Bot Protection) -----------------------------------
# https://app.arcjet.com
ARCJET_KEY=

# -- Development only (do NOT set in Vercel) -----------------------------------
# Suppresses Arcjet "Client IP address is missing" warning in local dev
# ARCJET_ENV=development
